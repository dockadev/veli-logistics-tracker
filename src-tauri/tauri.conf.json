{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VELI Logistics Tracker",
  "version": "0.1.66",
  "identifier": "com.dockadev.logi-app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Veli Logistics Tracker",
        "width": 1500,
        "height": 880,
        "resizable": true,
        "decorations": true,
        "center": true,
        "visible": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
